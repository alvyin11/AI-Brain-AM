# Copy to .env and fill. NEVER commit .env (gitignored).

# --- Supabase ---
SUPABASE_URL=https://dogwxbuxlalrrtpvexmx.supabase.co
SUPABASE_SERVICE_KEY=<service_role secret JWT>
# Direct connection. If the VPS has no IPv6, use the Session Pooler URI from
# app.supabase.com -> Project Settings -> Database -> Connection string.
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.dogwxbuxlalrrtpvexmx.supabase.co:5432/postgres

# --- LLM ---
OPENROUTER_API_KEY=<openrouter key>
MODEL=anthropic/claude-sonnet-4.6
MAX_TOKENS=8192

# --- RAG ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=amdk_knowledge
OPENAI_API_KEY=<openai key for text-embedding-3-small>   # PLACEHOLDER — same key the n8n embeddings credential uses

# --- External APIs (same values as the n8n workflows) ---
DATAFORSEO_AUTH=<base64 login:password>
WP_BASE_URL=https://amdigitalke.com/wp-json/wp/v2
WP_AUTH=<base64 wp application password>
LOCATION_CODE=2404
CLIENT_ID=amdk

# --- GA4 / GSC (OPTIONAL until configured; tools answer 'not configured' meanwhile) ---
GOOGLE_SERVICE_ACCOUNT_JSON=            # path to service-account .json inside the container
GSC_SITE=sc-domain:amdigitalke.com
GA4_PROPERTY_ID=

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LangSmith tracing (optional but recommended) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=<langsmith key>
LANGSMITH_PROJECT=amdk-brain
